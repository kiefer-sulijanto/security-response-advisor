{
  "intrusion_attempt": {
    "events": ["person_detected", "access_denied"],
    "time_window": 60,
    "description": "Possible unauthorized entry attempt"
  },
  "unauthorized_access": {
    "events": ["restricted_area_entry"],
    "time_window": 60,
    "description": "Person entered restricted area"
  },
  "loitering": {
    "events": ["loitering_detected"],
    "time_window": 60,
    "description": "Person loitering in monitored area"
  },
  "after_hours_presence": {
    "events": ["person_detected", "after_hours_presence"],
    "time_window": 60,
    "description": "Person detected in monitored area during restricted hours"
  },
  "tailgating": {
    "events": ["access_granted", "multiple_persons_detected"],
    "time_window": 10,
    "description": "Possible tailgating through controlled entry"
  },
  "emergency_distress": {
    "events": ["panic_button"],
    "time_window": 10,
    "description": "Emergency panic alert triggered"
  },
  "fire_alert": {
    "events": ["smoke_detected"],
    "time_window": 30,
    "description": "Possible fire detected"
  }
}